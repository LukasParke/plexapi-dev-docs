{
  "openapi": "3.1.0",
  "info": {
    "title": "Plex Media Server API",
    "description": "Machine-readable contract for the most-used endpoints of the Plex Media Server HTTP API. This spec is the single source of truth for reference documentation and future SDK generation at PlexAPI.dev.",
    "version": "0.1.0",
    "contact": {
      "name": "PlexAPI.dev",
      "url": "https://plexapi.dev"
    },
    "license": {
      "name": "MIT",
      "identifier": "MIT"
    }
  },
  "servers": [
    {
      "url": "{protocol}://{host}:{port}",
      "description": "Local Plex Media Server",
      "variables": {
        "protocol": {
          "default": "http",
          "enum": ["http", "https"]
        },
        "host": {
          "default": "localhost"
        },
        "port": {
          "default": "32400"
        }
      }
    }
  ],
  "security": [
    {
      "plexToken": []
    }
  ],
  "tags": [
    {
      "name": "Server",
      "description": "Server discovery, identity, and top-level status."
    },
    {
      "name": "Library",
      "description": "Library sections and the items they contain."
    },
    {
      "name": "Sessions",
      "description": "Active playback sessions and transcoding status."
    }
  ],
  "paths": {
    "/identity": {
      "get": {
        "operationId": "getIdentity",
        "summary": "Get server identity",
        "description": "Returns the server's identity, including its unique Machine Identifier. This endpoint does not require authentication and is commonly used for server discovery.",
        "tags": ["Server"],
        "security": [],
        "parameters": [
          {
            "$ref": "#/components/parameters/AcceptHeader"
          }
        ],
        "responses": {
          "200": {
            "description": "Server identity.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MediaContainerIdentity"
                }
              }
            }
          }
        }
      }
    },
    "/": {
      "get": {
        "operationId": "getServerInfo",
        "summary": "Get server information",
        "description": "Returns the server root MediaContainer, including friendly name, platform, version, and available features.",
        "tags": ["Server"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AcceptHeader"
          }
        ],
        "responses": {
          "200": {
            "description": "Server information.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MediaContainerServer"
                }
              }
            }
          }
        }
      }
    },
    "/library/sections": {
      "get": {
        "operationId": "getLibrarySections",
        "summary": "List library sections",
        "description": "Returns all configured library sections (movies, TV shows, music, photos, etc.).",
        "tags": ["Library"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AcceptHeader"
          }
        ],
        "responses": {
          "200": {
            "description": "Library sections.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MediaContainerLibrarySections"
                }
              }
            }
          }
        }
      }
    },
    "/library/sections/{sectionKey}/all": {
      "get": {
        "operationId": "getLibraryItems",
        "summary": "List items in a library section",
        "description": "Returns all items within a specific library section. Use query parameters such as `type` and `includeCollections` to narrow results.",
        "tags": ["Library"],
        "parameters": [
          {
            "name": "sectionKey",
            "in": "path",
            "required": true,
            "description": "The key of the library section, as returned by `/library/sections`.",
            "schema": {
              "type": "string"
            }
          },
          {
            "$ref": "#/components/parameters/AcceptHeader"
          },
          {
            "name": "type",
            "in": "query",
            "description": "Filter by media type integer (e.g., 1 for movies, 2 for shows, 8 for artists).",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "includeCollections",
            "in": "query",
            "description": "Include collection items in the response.",
            "schema": {
              "type": "integer",
              "enum": [0, 1]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Library items.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MediaContainerLibraryItems"
                }
              }
            }
          }
        }
      }
    },
    "/status/sessions": {
      "get": {
        "operationId": "getSessions",
        "summary": "List active sessions",
        "description": "Returns currently active playback sessions, including player state, user, and media being played.",
        "tags": ["Sessions"],
        "x-plex-resource": "Sessions",
        "parameters": [
          {
            "$ref": "#/components/parameters/AcceptHeader"
          }
        ],
        "responses": {
          "200": {
            "description": "Active sessions.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MediaContainerSessions"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "plexToken": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Plex-Token",
        "description": "Plex authentication token. Obtain from https://www.plex.tv/claim/ or a signed-in Plex account. Never commit tokens to source control."
      }
    },
    "parameters": {
      "AcceptHeader": {
        "name": "Accept",
        "in": "header",
        "description": "Request JSON responses by setting `application/json`. Plex defaults to XML when omitted.",
        "schema": {
          "type": "string",
          "enum": ["application/json", "application/xml"]
        }
      }
    },
    "schemas": {
      "MediaContainerIdentity": {
        "type": "object",
        "description": "Root wrapper for identity responses.",
        "properties": {
          "MediaContainer": {
            "$ref": "#/components/schemas/Identity"
          }
        }
      },
      "Identity": {
        "type": "object",
        "description": "Server identity details.",
        "properties": {
          "size": {
            "type": "integer"
          },
          "claimed": {
            "type": "boolean"
          },
          "machineIdentifier": {
            "type": "string",
            "description": "Unique machine identifier for this server."
          },
          "version": {
            "type": "string"
          }
        }
      },
      "MediaContainerServer": {
        "type": "object",
        "description": "Root wrapper for server root responses.",
        "properties": {
          "MediaContainer": {
            "$ref": "#/components/schemas/ServerInfo"
          }
        }
      },
      "ServerInfo": {
        "type": "object",
        "description": "Server-level status and capabilities.",
        "properties": {
          "size": {
            "type": "integer"
          },
          "allowCameraUpload": {
            "type": "boolean"
          },
          "allowMediaDeletion": {
            "type": "boolean"
          },
          "allowSharing": {
            "type": "boolean"
          },
          "allowSync": {
            "type": "boolean"
          },
          "backgroundProcessing": {
            "type": "boolean"
          },
          "certificate": {
            "type": "boolean"
          },
          "companionProxy": {
            "type": "boolean"
          },
          "countryCode": {
            "type": "string"
          },
          "diagnostics": {
            "type": "string"
          },
          "eventSource": {
            "type": "boolean"
          },
          "friendlyName": {
            "type": "string"
          },
          "livetv": {
            "type": "integer"
          },
          "machineIdentifier": {
            "type": "string"
          },
          "myPlex": {
            "type": "boolean"
          },
          "myPlexMappingState": {
            "type": "string"
          },
          "myPlexSigninState": {
            "type": "string"
          },
          "myPlexSubscription": {
            "type": "boolean"
          },
          "myPlexUsername": {
            "type": "string"
          },
          "offlineTranscode": {
            "type": "integer"
          },
          "ownerFeatures": {
            "type": "string"
          },
          "photoAutoTag": {
            "type": "boolean"
          },
          "platform": {
            "type": "string"
          },
          "platformVersion": {
            "type": "string"
          },
          "pluginHost": {
            "type": "boolean"
          },
          "pushNotifications": {
            "type": "boolean"
          },
          "readOnlyLibraries": {
            "type": "boolean"
          },
          "streamingBrainVersion": {
            "type": "integer"
          },
          "sync": {
            "type": "boolean"
          },
          "transcoderActiveVideoSessions": {
            "type": "integer"
          },
          "transcoderAudio": {
            "type": "boolean"
          },
          "transcoderLyrics": {
            "type": "boolean"
          },
          "transcoderPhoto": {
            "type": "boolean"
          },
          "transcoderSubtitles": {
            "type": "boolean"
          },
          "transcoderVideo": {
            "type": "boolean"
          },
          "updatedAt": {
            "type": "integer",
            "description": "Unix timestamp of the last server update."
          },
          "updater": {
            "type": "boolean"
          },
          "version": {
            "type": "string"
          },
          "voiceSearch": {
            "type": "boolean"
          },
          "Directory": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ServerCapability"
            }
          }
        }
      },
      "ServerCapability": {
        "type": "object",
        "description": "A capability or service exposed by the server root.",
        "properties": {
          "count": {
            "type": "integer"
          },
          "key": {
            "type": "string"
          },
          "title": {
            "type": "string"
          }
        }
      },
      "MediaContainerLibrarySections": {
        "type": "object",
        "description": "Root wrapper for library section listings.",
        "properties": {
          "MediaContainer": {
            "$ref": "#/components/schemas/LibrarySections"
          }
        }
      },
      "LibrarySections": {
        "type": "object",
        "description": "Collection of library sections.",
        "properties": {
          "size": {
            "type": "integer"
          },
          "allowSync": {
            "type": "boolean"
          },
          "art": {
            "type": "string"
          },
          "identifier": {
            "type": "string"
          },
          "mediaTagPrefix": {
            "type": "string"
          },
          "mediaTagVersion": {
            "type": "integer"
          },
          "title1": {
            "type": "string"
          },
          "title2": {
            "type": "string"
          },
          "Directory": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LibrarySection"
            }
          }
        }
      },
      "LibrarySection": {
        "type": "object",
        "description": "A single library section (movie, show, artist, photo).",
        "properties": {
          "allowSync": {
            "type": "boolean"
          },
          "art": {
            "type": "string"
          },
          "composite": {
            "type": "string"
          },
          "filters": {
            "type": "boolean"
          },
          "refreshing": {
            "type": "boolean"
          },
          "thumb": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["movie", "show", "artist", "photo"]
          },
          "title": {
            "type": "string"
          },
          "agent": {
            "type": "string"
          },
          "scanner": {
            "type": "string"
          },
          "language": {
            "type": "string"
          },
          "uuid": {
            "type": "string"
          },
          "updatedAt": {
            "type": "integer"
          },
          "createdAt": {
            "type": "integer"
          },
          "scannedAt": {
            "type": "integer"
          },
          "content": {
            "type": "boolean"
          },
          "directory": {
            "type": "boolean"
          },
          "contentChangedAt": {
            "type": "integer"
          },
          "hidden": {
            "type": "integer"
          },
          "Location": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LibrarySectionLocation"
            }
          }
        }
      },
      "LibrarySectionLocation": {
        "type": "object",
        "description": "Filesystem location backing a library section.",
        "properties": {
          "id": {
            "type": "integer"
          },
          "path": {
            "type": "string"
          }
        }
      },
      "MediaContainerLibraryItems": {
        "type": "object",
        "description": "Root wrapper for library item listings.",
        "properties": {
          "MediaContainer": {
            "$ref": "#/components/schemas/LibraryItems"
          }
        }
      },
      "LibraryItems": {
        "type": "object",
        "description": "Collection of items within a library section.",
        "properties": {
          "size": {
            "type": "integer"
          },
          "allowSync": {
            "type": "boolean"
          },
          "art": {
            "type": "string"
          },
          "identifier": {
            "type": "string"
          },
          "librarySectionID": {
            "type": "integer"
          },
          "librarySectionTitle": {
            "type": "string"
          },
          "librarySectionUUID": {
            "type": "string"
          },
          "mediaTagPrefix": {
            "type": "string"
          },
          "mediaTagVersion": {
            "type": "integer"
          },
          "nocache": {
            "type": "boolean"
          },
          "offset": {
            "type": "integer"
          },
          "totalSize": {
            "type": "integer"
          },
          "title1": {
            "type": "string"
          },
          "title2": {
            "type": "string"
          },
          "viewGroup": {
            "type": "string"
          },
          "viewMode": {
            "type": "integer"
          },
          "Metadata": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MediaItem"
            }
          }
        }
      },
      "MediaItem": {
        "type": "object",
        "description": "Base fields common to movies, episodes, tracks, and photos.",
        "properties": {
          "ratingKey": {
            "type": "string"
          },
          "key": {
            "type": "string"
          },
          "parentRatingKey": {
            "type": "string"
          },
          "grandparentRatingKey": {
            "type": "string"
          },
          "guid": {
            "type": "string"
          },
          "parentGuid": {
            "type": "string"
          },
          "grandparentGuid": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["movie", "show", "season", "episode", "artist", "album", "track", "photo", "photoalbum"]
          },
          "title": {
            "type": "string"
          },
          "titleSort": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "thumb": {
            "type": "string"
          },
          "art": {
            "type": "string"
          },
          "banner": {
            "type": "string"
          },
          "theme": {
            "type": "string"
          },
          "duration": {
            "type": "integer"
          },
          "addedAt": {
            "type": "integer"
          },
          "updatedAt": {
            "type": "integer"
          },
          "originallyAvailableAt": {
            "type": "string",
            "format": "date"
          },
          "rating": {
            "type": "number"
          },
          "userRating": {
            "type": "number"
          },
          "viewCount": {
            "type": "integer"
          },
          "lastViewedAt": {
            "type": "integer"
          },
          "year": {
            "type": "integer"
          },
          "studio": {
            "type": "string"
          },
          "tagline": {
            "type": "string"
          },
          "contentRating": {
            "type": "string"
          },
          "audienceRating": {
            "type": "number"
          },
          "audienceRatingImage": {
            "type": "string"
          },
          "chapterSource": {
            "type": "string"
          },
          "primaryExtraKey": {
            "type": "string"
          }
        }
      },
      "MediaContainerSessions": {
        "type": "object",
        "description": "Root wrapper for active session listings.",
        "properties": {
          "MediaContainer": {
            "$ref": "#/components/schemas/Sessions"
          }
        }
      },
      "Sessions": {
        "type": "object",
        "description": "Collection of active playback sessions.",
        "properties": {
          "size": {
            "type": "integer"
          },
          "Metadata": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Session"
            }
          }
        }
      },
      "Session": {
        "type": "object",
        "description": "An active playback session, extending a media item with player and session details.",
        "allOf": [
          {
            "$ref": "#/components/schemas/MediaItem"
          },
          {
            "type": "object",
            "properties": {
              "Session": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "bandwidth": {
                    "type": "integer"
                  },
                  "location": {
                    "type": "string"
                  },
                  "data": {
                    "type": "string"
                  }
                }
              },
              "Player": {
                "type": "object",
                "properties": {
                  "address": {
                    "type": "string"
                  },
                  "device": {
                    "type": "string"
                  },
                  "machineIdentifier": {
                    "type": "string"
                  },
                  "model": {
                    "type": "string"
                  },
                  "platform": {
                    "type": "string"
                  },
                  "platformVersion": {
                    "type": "string"
                  },
                  "product": {
                    "type": "string"
                  },
                  "profile": {
                    "type": "string"
                  },
                  "remotePublicAddress": {
                    "type": "string"
                  },
                  "state": {
                    "type": "string",
                    "enum": ["playing", "paused", "buffering", "stopped"]
                  },
                  "title": {
                    "type": "string"
                  },
                  "userID": {
                    "type": "string"
                  },
                  "vendor": {
                    "type": "string"
                  },
                  "version": {
                    "type": "string"
                  },
                  "local": {
                    "type": "boolean"
                  },
                  "relayed": {
                    "type": "boolean"
                  },
                  "secure": {
                    "type": "boolean"
                  },
                  "throttled": {
                    "type": "boolean"
                  }
                }
              },
              "User": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "title": {
                    "type": "string"
                  },
                  "thumb": {
                    "type": "string"
                  }
                }
              },
              "TranscodeSession": {
                "type": "object",
                "properties": {
                  "key": {
                    "type": "string"
                  },
                  "throttled": {
                    "type": "boolean"
                  },
                  "complete": {
                    "type": "boolean"
                  },
                  "progress": {
                    "type": "number"
                  },
                  "size": {
                    "type": "integer"
                  },
                  "speed": {
                    "type": "number"
                  },
                  "error": {
                    "type": "boolean"
                  },
                  "duration": {
                    "type": "integer"
                  },
                  "context": {
                    "type": "string"
                  },
                  "sourceVideoCodec": {
                    "type": "string"
                  },
                  "sourceAudioCodec": {
                    "type": "string"
                  },
                  "videoDecision": {
                    "type": "string"
                  },
                  "audioDecision": {
                    "type": "string"
                  },
                  "protocol": {
                    "type": "string"
                  },
                  "container": {
                    "type": "string"
                  }
                }
              }
            }
          }
        ]
      }
    }
  }
}

{
  "openapi": "3.1.0",
  "info": {
    "title": "Plex Media Server API",
    "description": "Machine-readable contract for the most-used endpoints of the Plex Media Server HTTP API. This spec is the single source of truth for reference documentation and future SDK generation at PlexAPI.dev.",
    "version": "0.1.0",
    "contact": {
      "name": "PlexAPI.dev",
      "url": "https://plexapi.dev"
    },
    "license": {
      "name": "MIT",
      "identifier": "MIT"
    }
  },
  "servers": [
    {
      "url": "{protocol}://{host}:{port}",
      "description": "Local Plex Media Server",
      "variables": {
        "protocol": {
          "default": "http",
          "enum": ["http", "https"]
        },
        "host": {
          "default": "localhost"
        },
        "port": {
          "default": "32400"
        }
      }
    }
  ],
  "security": [
    {
      "plexToken": []
    }
  ],
  "tags": [
    {
      "name": "Server",
      "description": "Server discovery, identity, and top-level status."
    },
    {
      "name": "Library",
      "description": "Library sections and the items they contain."
    },
    {
      "name": "Sessions",
      "description": "Active playback sessions and transcoding status."
    },
    {
      "name": "Metadata",
      "description": "Item-level metadata and relationships."
    },
    {
      "name": "Playlists",
      "description": "Playlists and playlist items."
    },
    {
      "name": "Hub",
      "description": "Global and per-library search hubs."
    }
  ],
  "paths": {
    "/identity": {
      "get": {
        "operationId": "getIdentity",
        "summary": "Get server identity",
        "description": "Returns the server's identity, including its unique Machine Identifier. This endpoint does not require authentication and is commonly used for server discovery.",
        "tags": ["Server"],
        "x-plex-resource": "Server",
        "security": [],
        "parameters": [
          {
            "$ref": "#/components/parameters/AcceptHeader"
          }
        ],
        "responses": {
          "200": {
            "description": "Server identity.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MediaContainerIdentity"
                }
              }
            }
          }
        }
      }
    },
    "/": {
      "get": {
        "operationId": "getServerInfo",
        "summary": "Get server information",
        "description": "Returns the server root MediaContainer, including friendly name, platform, version, and available features.",
        "tags": ["Server"],
        "x-plex-resource": "Server",
        "parameters": [
          {
            "$ref": "#/components/parameters/AcceptHeader"
          }
        ],
        "responses": {
          "200": {
            "description": "Server information.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MediaContainerServer"
                }
              }
            }
          }
        }
      }
    },
    "/library/sections": {
      "get": {
        "operationId": "getLibrarySections",
        "summary": "List library sections",
        "description": "Returns all configured library sections (movies, TV shows, music, photos, etc.).",
        "tags": ["Library"],
        "x-plex-resource": "Library",
        "parameters": [
          {
            "$ref": "#/components/parameters/AcceptHeader"
          }
        ],
        "responses": {
          "200": {
            "description": "Library sections.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MediaContainerLibrarySections"
                }
              }
            }
          }
        }
      }
    },
    "/library/sections/{sectionKey}/all": {
      "get": {
        "operationId": "getLibraryItems",
        "summary": "List items in a library section",
        "description": "Returns all items within a specific library section. Use query parameters such as `type` and `includeCollections` to narrow results.",
        "tags": ["Library"],
        "x-plex-resource": "Library",
        "parameters": [
          {
            "name": "sectionKey",
            "in": "path",
            "required": true,
            "description": "The key of the library section, as returned by `/library/sections`.",
            "schema": {
              "type": "string"
            }
          },
          {
            "$ref": "#/components/parameters/AcceptHeader"
          },
          {
            "name": "type",
            "in": "query",
            "description": "Filter by media type integer (e.g., 1 for movies, 2 for shows, 8 for artists).",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "includeCollections",
            "in": "query",
            "description": "Include collection items in the response.",
            "schema": {
              "type": "integer",
              "enum": [0, 1]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Library items.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MediaContainerLibraryItems"
                }
              }
            }
          }
        }
      }
    },
    "/library/sections/{sectionKey}/refresh": {
      "post": {
        "operationId": "refreshLibrarySection",
        "summary": "Refresh a library section",
        "description": "Triggers a metadata refresh for the specified library section.",
        "tags": ["Library"],
        "x-plex-resource": "Library",
        "parameters": [
          {
            "name": "sectionKey",
            "in": "path",
            "required": true,
            "description": "The key of the library section.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "force",
            "in": "query",
            "description": "Force a full metadata refresh.",
            "schema": {
              "type": "integer",
              "enum": [0, 1]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Refresh accepted."
          }
        }
      }
    },
    "/library/sections/{sectionKey}/search": {
      "get": {
        "operationId": "searchLibrarySection",
        "summary": "Search within a library section",
        "description": "Returns search results scoped to a single library section.",
        "tags": ["Hub"],
        "x-plex-resource": "Hub",
        "parameters": [
          {
            "name": "sectionKey",
            "in": "path",
            "required": true,
            "description": "The key of the library section.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "query",
            "in": "query",
            "required": true,
            "description": "Search query string.",
            "schema": {
              "type": "string"
            }
          },
          {
            "$ref": "#/components/parameters/AcceptHeader"
          }
        ],
        "responses": {
          "200": {
            "description": "Section search results.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MediaContainerHub"
                }
              }
            }
          }
        }
      }
    },
    "/library/metadata/{ratingKey}": {
      "get": {
        "operationId": "getMetadata",
        "summary": "Get metadata for an item",
        "description": "Returns full metadata for a single item by its rating key.",
        "tags": ["Metadata"],
        "x-plex-resource": "Metadata",
        "parameters": [
          {
            "name": "ratingKey",
            "in": "path",
            "required": true,
            "description": "The rating key of the item.",
            "schema": {
              "type": "string"
            }
          },
          {
            "$ref": "#/components/parameters/AcceptHeader"
          }
        ],
        "responses": {
          "200": {
            "description": "Item metadata.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MediaContainerMetadata"
                }
              }
            }
          }
        }
      }
    },
    "/library/metadata/{ratingKey}/children": {
      "get": {
        "operationId": "getMetadataChildren",
        "summary": "Get children of an item",
        "description": "Returns child items for a metadata object, such as seasons of a show or episodes of a season.",
        "tags": ["Metadata"],
        "x-plex-resource": "Metadata",
        "parameters": [
          {
            "name": "ratingKey",
            "in": "path",
            "required": true,
            "description": "The rating key of the parent item.",
            "schema": {
              "type": "string"
            }
          },
          {
            "$ref": "#/components/parameters/AcceptHeader"
          }
        ],
        "responses": {
          "200": {
            "description": "Child items.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MediaContainerMetadataChildren"
                }
              }
            }
          }
        }
      }
    },
    "/status/sessions": {
      "get": {
        "operationId": "getSessions",
        "summary": "List active sessions",
        "description": "Returns currently active playback sessions, including player state, user, and media being played.",
        "tags": ["Sessions"],
        "x-plex-resource": "Sessions",
        "parameters": [
          {
            "$ref": "#/components/parameters/AcceptHeader"
          }
        ],
        "responses": {
          "200": {
            "description": "Active sessions.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MediaContainerSessions"
                }
              }
            }
          }
        }
      }
    },
    "/playlists": {
      "get": {
        "operationId": "getPlaylists",
        "summary": "List playlists",
        "description": "Returns all playlists for the authenticated user.",
        "tags": ["Playlists"],
        "x-plex-resource": "Playlists",
        "parameters": [
          {
            "$ref": "#/components/parameters/AcceptHeader"
          }
        ],
        "responses": {
          "200": {
            "description": "Playlists.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MediaContainerPlaylists"
                }
              }
            }
          }
        }
      }
    },
    "/playlists/{playlistKey}/items": {
      "get": {
        "operationId": "getPlaylistItems",
        "summary": "Get playlist items",
        "description": "Returns the items contained in a playlist.",
        "tags": ["Playlists"],
        "x-plex-resource": "Playlists",
        "parameters": [
          {
            "name": "playlistKey",
            "in": "path",
            "required": true,
            "description": "The key of the playlist.",
            "schema": {
              "type": "string"
            }
          },
          {
            "$ref": "#/components/parameters/AcceptHeader"
          }
        ],
        "responses": {
          "200": {
            "description": "Playlist items.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MediaContainerPlaylistItems"
                }
              }
            }
          }
        }
      }
    },
    "/hubs/search": {
      "get": {
        "operationId": "searchHubs",
        "summary": "Global search across hubs",
        "description": "Returns search results grouped by hub across all libraries.",
        "tags": ["Hub"],
        "x-plex-resource": "Hub",
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "description": "Search query string.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum results per hub.",
            "schema": {
              "type": "integer",
              "default": 5
            }
          },
          {
            "$ref": "#/components/parameters/AcceptHeader"
          }
        ],
        "responses": {
          "200": {
            "description": "Grouped search results.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MediaContainerHub"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "plexToken": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Plex-Token",
        "description": "Plex authentication token. Obtain from https://www.plex.tv/claim/ or a signed-in Plex account. Never commit tokens to source control."
      }
    },
    "parameters": {
      "AcceptHeader": {
        "name": "Accept",
        "in": "header",
        "description": "Request JSON responses by setting `application/json`. Plex defaults to XML when omitted.",
        "schema": {
          "type": "string",
          "enum": ["application/json", "application/xml"]
        }
      }
    },
    "schemas": {
      "MediaContainerIdentity": {
        "type": "object",
        "description": "Root wrapper for identity responses.",
        "properties": {
          "MediaContainer": {
            "$ref": "#/components/schemas/Identity"
          }
        }
      },
      "Identity": {
        "type": "object",
        "description": "Server identity details.",
        "properties": {
          "size": {
            "type": "integer"
          },
          "claimed": {
            "type": "boolean"
          },
          "machineIdentifier": {
            "type": "string",
            "description": "Unique machine identifier for this server."
          },
          "version": {
            "type": "string"
          }
        }
      },
      "MediaContainerServer": {
        "type": "object",
        "description": "Root wrapper for server root responses.",
        "properties": {
          "MediaContainer": {
            "$ref": "#/components/schemas/ServerInfo"
          }
        }
      },
      "ServerInfo": {
        "type": "object",
        "description": "Server-level status and capabilities.",
        "properties": {
          "size": {
            "type": "integer"
          },
          "allowCameraUpload": {
            "type": "boolean"
          },
          "allowMediaDeletion": {
            "type": "boolean"
          },
          "allowSharing": {
            "type": "boolean"
          },
          "allowSync": {
            "type": "boolean"
          },
          "backgroundProcessing": {
            "type": "boolean"
          },
          "certificate": {
            "type": "boolean"
          },
          "companionProxy": {
            "type": "boolean"
          },
          "countryCode": {
            "type": "string"
          },
          "diagnostics": {
            "type": "string"
          },
          "eventSource": {
            "type": "boolean"
          },
          "friendlyName": {
            "type": "string"
          },
          "livetv": {
            "type": "integer"
          },
          "machineIdentifier": {
            "type": "string"
          },
          "myPlex": {
            "type": "boolean"
          },
          "myPlexMappingState": {
            "type": "string"
          },
          "myPlexSigninState": {
            "type": "string"
          },
          "myPlexSubscription": {
            "type": "boolean"
          },
          "myPlexUsername": {
            "type": "string"
          },
          "offlineTranscode": {
            "type": "integer"
          },
          "ownerFeatures": {
            "type": "string"
          },
          "photoAutoTag": {
            "type": "boolean"
          },
          "platform": {
            "type": "string"
          },
          "platformVersion": {
            "type": "string"
          },
          "pluginHost": {
            "type": "boolean"
          },
          "pushNotifications": {
            "type": "boolean"
          },
          "readOnlyLibraries": {
            "type": "boolean"
          },
          "streamingBrainVersion": {
            "type": "integer"
          },
          "sync": {
            "type": "boolean"
          },
          "transcoderActiveVideoSessions": {
            "type": "integer"
          },
          "transcoderAudio": {
            "type": "boolean"
          },
          "transcoderLyrics": {
            "type": "boolean"
          },
          "transcoderPhoto": {
            "type": "boolean"
          },
          "transcoderSubtitles": {
            "type": "boolean"
          },
          "transcoderVideo": {
            "type": "boolean"
          },
          "updatedAt": {
            "type": "integer",
            "description": "Unix timestamp of the last server update."
          },
          "updater": {
            "type": "boolean"
          },
          "version": {
            "type": "string"
          },
          "voiceSearch": {
            "type": "boolean"
          },
          "Directory": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ServerCapability"
            }
          }
        }
      },
      "ServerCapability": {
        "type": "object",
        "description": "A capability or service exposed by the server root.",
        "properties": {
          "count": {
            "type": "integer"
          },
          "key": {
            "type": "string"
          },
          "title": {
            "type": "string"
          }
        }
      },
      "MediaContainerLibrarySections": {
        "type": "object",
        "description": "Root wrapper for library section listings.",
        "properties": {
          "MediaContainer": {
            "$ref": "#/components/schemas/LibrarySections"
          }
        }
      },
      "LibrarySections": {
        "type": "object",
        "description": "Collection of library sections.",
        "properties": {
          "size": {
            "type": "integer"
          },
          "allowSync": {
            "type": "boolean"
          },
          "art": {
            "type": "string"
          },
          "identifier": {
            "type": "string"
          },
          "mediaTagPrefix": {
            "type": "string"
          },
          "mediaTagVersion": {
            "type": "integer"
          },
          "title1": {
            "type": "string"
          },
          "title2": {
            "type": "string"
          },
          "Directory": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LibrarySection"
            }
          }
        }
      },
      "LibrarySection": {
        "type": "object",
        "description": "A single library section (movie, show, artist, photo).",
        "properties": {
          "allowSync": {
            "type": "boolean"
          },
          "art": {
            "type": "string"
          },
          "composite": {
            "type": "string"
          },
          "filters": {
            "type": "boolean"
          },
          "refreshing": {
            "type": "boolean"
          },
          "thumb": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["movie", "show", "artist", "photo"]
          },
          "title": {
            "type": "string"
          },
          "agent": {
            "type": "string"
          },
          "scanner": {
            "type": "string"
          },
          "language": {
            "type": "string"
          },
          "uuid": {
            "type": "string"
          },
          "updatedAt": {
            "type": "integer"
          },
          "createdAt": {
            "type": "integer"
          },
          "scannedAt": {
            "type": "integer"
          },
          "content": {
            "type": "boolean"
          },
          "directory": {
            "type": "boolean"
          },
          "contentChangedAt": {
            "type": "integer"
          },
          "hidden": {
            "type": "integer"
          },
          "Location": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LibrarySectionLocation"
            }
          }
        }
      },
      "LibrarySectionLocation": {
        "type": "object",
        "description": "Filesystem location backing a library section.",
        "properties": {
          "id": {
            "type": "integer"
          },
          "path": {
            "type": "string"
          }
        }
      },
      "MediaContainerLibraryItems": {
        "type": "object",
        "description": "Root wrapper for library item listings.",
        "properties": {
          "MediaContainer": {
            "$ref": "#/components/schemas/LibraryItems"
          }
        }
      },
      "LibraryItems": {
        "type": "object",
        "description": "Collection of items within a library section.",
        "properties": {
          "size": {
            "type": "integer"
          },
          "allowSync": {
            "type": "boolean"
          },
          "art": {
            "type": "string"
          },
          "identifier": {
            "type": "string"
          },
          "librarySectionID": {
            "type": "integer"
          },
          "librarySectionTitle": {
            "type": "string"
          },
          "librarySectionUUID": {
            "type": "string"
          },
          "mediaTagPrefix": {
            "type": "string"
          },
          "mediaTagVersion": {
            "type": "integer"
          },
          "nocache": {
            "type": "boolean"
          },
          "offset": {
            "type": "integer"
          },
          "totalSize": {
            "type": "integer"
          },
          "title1": {
            "type": "string"
          },
          "title2": {
            "type": "string"
          },
          "viewGroup": {
            "type": "string"
          },
          "viewMode": {
            "type": "integer"
          },
          "Metadata": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MediaItem"
            }
          }
        }
      },
      "MediaItem": {
        "type": "object",
        "description": "Base fields common to movies, episodes, tracks, and photos.",
        "properties": {
          "ratingKey": {
            "type": "string"
          },
          "key": {
            "type": "string"
          },
          "parentRatingKey": {
            "type": "string"
          },
          "grandparentRatingKey": {
            "type": "string"
          },
          "guid": {
            "type": "string"
          },
          "parentGuid": {
            "type": "string"
          },
          "grandparentGuid": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["movie", "show", "season", "episode", "artist", "album", "track", "photo", "photoalbum"]
          },
          "title": {
            "type": "string"
          },
          "titleSort": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "thumb": {
            "type": "string"
          },
          "art": {
            "type": "string"
          },
          "banner": {
            "type": "string"
          },

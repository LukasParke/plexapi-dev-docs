          },
          "lastViewedAt": {
            "type": "integer"
          },
          "year": {
            "type": "integer"
          },
          "studio": {
            "type": "string"
          },
          "tagline": {
            "type": "string"
          },
          "contentRating": {
            "type": "string"
          },
          "audienceRating": {
            "type": "number"
          },
          "audienceRatingImage": {
            "type": "string"
          },
          "chapterSource": {
            "type": "string"
          },
          "primaryExtraKey": {
            "type": "string"
          },
          "Media": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Media"
            }
          },
          "Genre": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Tag"
            }
          },
          "Director": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Tag"
            }
          },
          "Writer": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Tag"
            }
          },
          "Role": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Tag"
            }
          }
        }
      },
      "Media": {
        "type": "object",
        "description": "Media container describing one or more file parts for a metadata item.",
        "properties": {
          "id": {
            "type": "integer"
          },
          "duration": {
            "type": "integer"
          },
          "bitrate": {
            "type": "integer"
          },
          "width": {
            "type": "integer"
          },
          "height": {
            "type": "integer"
          },
          "aspectRatio": {
            "type": "number"
          },
          "audioChannels": {
            "type": "integer"
          },
          "audioCodec": {
            "type": "string"
          },
          "videoCodec": {
            "type": "string"
          },
          "videoResolution": {
            "type": "string"

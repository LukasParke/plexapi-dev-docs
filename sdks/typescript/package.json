{
  "name": "@plexapi/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Plex Media Server API (proof of concept)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "generate:types": "openapi-typescript ../../schemas/plex-media-server.openapi.json -o src/types/openapi.ts",
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "example": "tsx examples/quickstart.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "plex",
    "plex-media-server",
    "sdk",
    "typescript"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.15.18",
    "openapi-typescript": "^7.8.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
